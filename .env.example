# API 访问控制（可选）
# 多个 token 用逗号分隔
API_TOKEN=your-secret-token-1,your-secret-token-2

# AI 提供商 Token（逗号分隔多个 Token）
HUGGINGFACE_TOKENS=hf_token1,hf_token2,hf_token3
GITEE_TOKENS=gitee_token1,gitee_token2
MODELSCOPE_TOKENS=ms_token1,ms_token2
A4F_TOKENS=a4f_token1,a4f_token2
GEMINI_TOKENS=gemini_token1,gemini_token2
GROK_TOKENS=xai_token1,xai_token2
OPENAI_TOKENS=sk-xxx1,sk-xxx2
MODELSLAB_TOKENS=modelslab_token1,modelslab_token2

# 可选的 API Base 配置 (若不填则使用默认官方地址)
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# GROK_API_BASE=https://api.x.ai/v1
# OPENAI_API_BASE=https://api.openai.com/v1

# ============================================
# S3 兼容存储配置（可选）
# ============================================
# 如果配置了以下环境变量，生成的图片/视频以及前台上传的素材将自动托管至 S3，获取持久可控的链接。
# S3_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket-name
# S3_CDN_URL=https://cdn.yourdomain.com

# ============================================
# 存储配置（选择其一）
# ============================================

# 选项 1: Vercel KV (Upstash Redis) - Vercel 部署推荐
# 在 Vercel 项目中创建 KV 存储后自动注入，无需手动配置
# KV_REST_API_URL=https://your-redis.upstash.io
# KV_REST_API_TOKEN=your-upstash-token

# 选项 2: 标准 Redis - 自建或第三方 Redis 服务
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://username:password@host:port

# 选项 3: Cloudflare KV - Cloudflare Workers 部署
# 在 wrangler.toml 中配置 KV binding，无需环境变量

# 选项 4: 内存存储 - 开发环境自动回退
# 无需配置，当以上选项都不可用时自动使用
