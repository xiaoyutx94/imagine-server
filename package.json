{
  "name": "imagine-server",
  "version": "1.3.0",
  "description": "Unified AI Image Generation API with multi-provider support (Hugging Face, Gitee AI, ModelScope)",
  "author": "Amery2010",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amery2010/imagine-server.git"
  },
  "type": "module",
  "main": "src/index.ts",
  "keywords": [
    "ai",
    "image-generation",
    "text-to-image",
    "flux",
    "stable-diffusion",
    "huggingface",
    "gitee-ai",
    "modelscope",
    "hono",
    "api",
    "cloudflare-workers",
    "vercel",
    "serverless"
  ],
  "scripts": {
    "dev": "tsx watch server/server.ts",
    "start": "NODE_ENV=production tsx server/server.ts",
    "start:prod": "NODE_ENV=production node server/server.js",
    "build": "tsx scripts/build-frontend.ts && tsc && fix-esm-import-path dist",
    "build:vercel": "tsx scripts/build-frontend.ts && tsc && fix-esm-import-path dist",
    "build:frontend": "tsx scripts/build-frontend.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "package": "tsx scripts/package.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "vercel:dev": "vercel dev",
    "vercel:build": "vercel build",
    "vercel:deploy": "vercel deploy",
    "vercel:prod": "vercel deploy --prod",
    "wrangler:dev": "wrangler dev",
    "wrangler:deploy": "wrangler deploy",
    "wrangler:tail": "wrangler tail"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@hono/zod-validator": "^0.7.6",
    "@upstash/redis": "^1.36.0",
    "aws4fetch": "^1.0.20",
    "dotenv": "^17.2.3",
    "hono": "^4.11.3",
    "ioredis": "^5.8.2",
    "unstorage": "^1.17.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251229.0",
    "@eslint/js": "^10.0.1",
    "@lando/vitepress-theme-default-plus": "^1.1.1",
    "@types/node": "^20.11.17",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fix-esm-import-path": "^1.10.3",
    "prettier": "^3.8.2",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9",
    "vue": "^3.5.26",
    "wrangler": "^4.54.0"
  }
}
